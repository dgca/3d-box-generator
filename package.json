{
  "name": "3d-box-generator-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace for the 3D Box Generator frontend and publishable core library.",
  "scripts": {
    "build": "pnpm --filter 3d-box-generator-frontend build",
    "dev": "pnpm --filter 3d-box-generator build && pnpm --parallel --filter 3d-box-generator --filter 3d-box-generator-frontend dev",
    "lint": "pnpm --filter 3d-box-generator typecheck && pnpm --filter 3d-box-generator-frontend lint"
  },
  "packageManager": "pnpm@10.33.0"
}
